---
/**
 * Article Detail Page
 *
 * Dynamic route that displays a full article with MDX content support, table of contents,
 * metadata, and structured data for SEO. Provides an optimized reading experience with
 * clean typography and responsive design.
 *
 * Features:
 * - MDX content rendering with full markdown support
 * - Automatic table of contents generation (when 3+ sections)
 * - Reading time calculation
 * - Article metadata (publish date, updated date, tags)
 * - Structured data for search engines
 * - Scroll-to-top functionality
 * - Back navigation to articles list
 * - Responsive typography
 *
 * Route: /writing/[slug]
 *
 * @page
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import SEO from "../../components/SEO.astro";
import StructuredData from "../../components/StructuredData.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import ScrollToTop from "../../components/ScrollToTop.astro";
import BackLink from "../../components/BackLink.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getReadingTime } from "../../utils/readingTime";
import { Image } from "astro:assets";

/**
 * Generates static paths for all published articles
 *
 * Queries the writing collection and filters for published articles only
 * (draft: false), creating a route for each article using its ID as the slug.
 *
 * @returns Array of path objects with params
 */
export async function getStaticPaths() {
  const articles = await getCollection("writing", ({ data }) => {
    return data.draft === false;
  });
  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const { slug } = Astro.params;

/**
 * Retrieves the specific article entry by slug
 *
 * Redirects to 404 if the article is not found.
 */
const article = await getEntry("writing", slug!);

if (!article) {
  return Astro.redirect("/404");
}

/**
 * Renders the article content and extracts headings
 *
 * The Content component renders the MDX, and headings are used for
 * the table of contents generation.
 */
const { Content, headings } = await render(article);

const {
  title,
  description,
  publishDate,
  updatedDate,
  tags,
  coverImage,
  coverImageCredit,
} = article.data;

/**
 * Calculates reading time from the article body
 *
 * Uses word count to estimate reading time in minutes.
 */
const readingTime = getReadingTime(article.body || "");

/**
 * Formats a date object for display
 *
 * Uses US English locale with full date format.
 * Example output: "January 15, 2024"
 *
 * @param date - The date to format
 * @returns Formatted date string
 */
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<BaseLayout>
  <SEO
    slot="head"
    title={`${title} - Writing`}
    description={description}
    type="article"
    publishDate={publishDate}
    updatedDate={updatedDate}
  />

  <StructuredData
    type="Article"
    data={{
      title,
      description,
      publishDate,
      updatedDate,
      tags,
      url: Astro.url.href,
    }}
  />

  <main class="article">
    <!-- Article Header -->
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <time class="publish-date" datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
        <span class="meta-separator">·</span>
        <span class="reading-time">{readingTime}</span>
        {
          updatedDate && (
            <>
              <span class="meta-separator">·</span>
              <time class="updated-date" datetime={updatedDate.toISOString()}>
                Updated {formatDate(updatedDate)}
              </time>
            </>
          )
        }
      </div>
      {
        tags && tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    {
      coverImage && (
        <figure class="article-cover-image">
          <Image src={coverImage} alt={`Cover image for ${title}`} />
          {coverImageCredit && (
            <figcaption class="image-credit">{coverImageCredit}</figcaption>
          )}
        </figure>
      )
    }

    <!-- Share Buttons -->
    <ShareButtons
      title={title}
      description={description}
      url={Astro.url.href}
    />

    <!-- Table of Contents (conditionally rendered if 3+ sections) -->
    <TableOfContents headings={headings} />

    <!-- Article Content -->
    <article class="article-content">
      <Content />
    </article>

    <!-- Share Buttons (Bottom) -->
    <ShareButtons
      title={title}
      description={description}
      url={Astro.url.href}
    />

    <BackLink href="/writing" text="All articles" />
  </main>

  <ScrollToTop />

  <style>
    .article {
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .article-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .article-header h1 {
      font-size: 2.75rem;
      margin-bottom: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.15;
      color: var(--color-text);
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9375rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    }

    .meta-separator {
      opacity: 0.5;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .tag {
      font-size: 0.8125rem;
      padding: 0.25rem 0.75rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-text-secondary);
    }

    .article-cover-image {
      margin: 0 0 2.5rem 0;
      border-radius: 8px;
      overflow: hidden;
    }

    .article-cover-image img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
      margin: 0;
    }

    .image-credit {
      text-align: center;
      font-size: 0.75rem;
      color: var(--color-text-muted);
      margin-top: 0.5rem;
      font-style: italic;
    }

    .article-content {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--color-text);
      letter-spacing: 0.002em;
    }

    .article-content :global(h2) {
      font-size: 1.875rem;
      margin-top: 3rem;
      margin-bottom: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.3;
      color: var(--color-text);
      scroll-margin-top: 2rem;
    }

    .article-content :global(h3) {
      font-size: 1.5rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      line-height: 1.4;
      color: var(--color-text);
      scroll-margin-top: 2rem;
    }

    .article-content :global(h4) {
      font-size: 1.125rem;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      font-weight: 600;
      line-height: 1.5;
      color: var(--color-text);
    }

    .article-content :global(p) {
      margin-bottom: 1.75rem;
      color: var(--color-text-secondary);
      max-width: 70ch;
    }

    .article-content :global(ul),
    .article-content :global(ol) {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
      color: var(--color-text-secondary);
    }

    .article-content :global(li) {
      margin-bottom: 0.5rem;
      line-height: 1.7;
    }

    /* Task list / checklist styles */
    .article-content :global(.contains-task-list) {
      list-style: none;
      padding-left: 0.25rem;
    }

    .article-content :global(.task-list-item) {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .article-content :global(.task-list-item input[type="checkbox"]) {
      appearance: none;
      -webkit-appearance: none;
      width: 1.15em;
      height: 1.15em;
      margin-top: 0.3em;
      border: 2px solid var(--color-text-muted, #666);
      border-radius: 3px;
      flex-shrink: 0;
      cursor: default;
      position: relative;
      background: transparent;
    }

    .article-content :global(.task-list-item input[type="checkbox"]:checked) {
      background: var(--color-accent, #4493f8);
      border-color: var(--color-accent, #4493f8);
    }

    .article-content
      :global(.task-list-item input[type="checkbox"]:checked::after) {
      content: "";
      position: absolute;
      left: 3px;
      top: 0px;
      width: 5px;
      height: 9px;
      border: solid #fff;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }

    .article-content :global(blockquote) {
      margin: 2.5rem 0;
      padding: 1.5rem 2rem;
      border-left: 4px solid var(--color-accent);
      background: var(--color-bg-secondary);
      font-style: italic;
      color: var(--color-text-secondary);
      border-radius: 0 8px 8px 0;
    }

    /* GitHub-style callout/alert overrides */
    .article-content :global(.markdown-alert) {
      font-style: normal;
      padding: 1rem 1.25rem;
      margin: 2rem 0;
      border-radius: 0 8px 8px 0;
      background: var(--color-bg-secondary);
    }

    .article-content :global(.markdown-alert-title) {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
      font-size: 0.9375rem;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .article-content :global(.markdown-alert p) {
      margin-bottom: 0.5rem;
      font-style: normal;
    }

    .article-content :global(.markdown-alert p:last-child) {
      margin-bottom: 0;
    }

    /* Note - blue */
    .article-content :global(.markdown-alert-note) {
      border-left: 4px solid #4493f8;
    }
    .article-content :global(.markdown-alert-note .markdown-alert-title) {
      color: #4493f8;
    }

    /* Tip - green */
    .article-content :global(.markdown-alert-tip) {
      border-left: 4px solid #3fb950;
    }
    .article-content :global(.markdown-alert-tip .markdown-alert-title) {
      color: #3fb950;
    }

    /* Important - purple */
    .article-content :global(.markdown-alert-important) {
      border-left: 4px solid #a371f7;
    }
    .article-content :global(.markdown-alert-important .markdown-alert-title) {
      color: #a371f7;
    }

    /* Warning - yellow/orange */
    .article-content :global(.markdown-alert-warning) {
      border-left: 4px solid #d29922;
    }
    .article-content :global(.markdown-alert-warning .markdown-alert-title) {
      color: #d29922;
    }

    /* Caution - red */
    .article-content :global(.markdown-alert-caution) {
      border-left: 4px solid #f85149;
    }
    .article-content :global(.markdown-alert-caution .markdown-alert-title) {
      color: #f85149;
    }

    .article-content :global(code) {
      font-family:
        ui-monospace, "JetBrains Mono", "Cascadia Code", Menlo, Consolas,
        "Courier New", monospace;
      font-size: 0.9em;
      background: var(--color-bg-secondary);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      color: var(--color-text);
    }

    .article-content :global(pre) {
      margin: 2rem 0;
      padding: 1.5rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow-x: auto;
    }

    .article-content :global(pre code) {
      background: none;
      padding: 0;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    .article-content :global(a) {
      color: var(--color-accent);
      text-decoration: underline;
    }

    .article-content :global(a:hover) {
      color: var(--color-accent-hover);
    }

    .article-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 2rem 0;
    }

    .article-content :global(hr) {
      margin: 3rem 0;
      border: none;
      border-top: 1px solid var(--color-border);
    }

    .article-content :global(strong) {
      color: var(--color-text);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .article {
        padding: 1.5rem 1rem;
      }

      .article-header h1 {
        font-size: 2rem;
      }

      .article-content {
        font-size: 1rem;
      }

      .article-content :global(h2) {
        font-size: 1.5rem;
      }

      .article-content :global(h3) {
        font-size: 1.25rem;
      }

      .article-content :global(h4) {
        font-size: 1.0625rem;
      }

      .article-content :global(pre) {
        padding: 1rem;
      }
    }
  </style>
</BaseLayout>
