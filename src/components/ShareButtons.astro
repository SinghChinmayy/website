---
/**
 * ShareButtons Component
 *
 * Provides social sharing buttons for content pages. Supports sharing to major
 * platforms including X (Twitter), WhatsApp, SMS, email, and copying link to clipboard.
 *
 * Features:
 * - Platform-specific share URLs with proper encoding
 * - Copy to clipboard with visual feedback
 * - Responsive design with mobile optimization
 * - SVG icons for consistent appearance
 * - Accessible button labels
 *
 * @component
 */

interface Props {
    /** Title of the content to share */
    title: string;
    /** Description of the content (used in email) */
    description?: string;
    /** URL to share (defaults to current page URL) */
    url?: string;
}

const { title, description = "", url = Astro.url.href } = Astro.props;

// Encode strings for URL parameters
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);
const encodedUrl = encodeURIComponent(url);

// Generate share URLs for each platform
const shareUrls = {
    twitter: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
    whatsapp: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
    sms: `sms:?&body=${encodedTitle}%20${encodedUrl}`,
    email: `mailto:?subject=${encodedTitle}&body=${encodedDescription}%20${encodedUrl}`,
};
---

<div class="share-buttons">
    <span class="share-label">Share:</span>
    <div class="share-actions">
        <!-- X (Twitter) -->
        <a
            href={shareUrls.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
            aria-label="Share on X (Twitter)"
            title="Share on X"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
                <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
            </svg>
        </a>

        <!-- WhatsApp -->
        <a
            href={shareUrls.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
            aria-label="Share on WhatsApp"
            title="Share on WhatsApp"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
                <path
                    d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
                ></path>
            </svg>
        </a>

        <!-- SMS -->
        <a
            href={shareUrls.sms}
            class="share-btn"
            aria-label="Share via SMS"
            title="Share via SMS"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
                <line x1="9" y1="10" x2="15" y2="10"></line>
                <line x1="9" y1="14" x2="13" y2="14"></line>
            </svg>
        </a>

        <!-- Email -->
        <a
            href={shareUrls.email}
            class="share-btn"
            aria-label="Share via Email"
            title="Share via Email"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
        </a>

        <!-- Copy Link -->
        <button
            class="share-btn copy-btn"
            data-url={url}
            aria-label="Copy link to clipboard"
            title="Copy link"
        >
            <svg
                class="copy-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                ></path>
                <path
                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                ></path>
            </svg>
            <svg
                class="check-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </button>
    </div>
</div>

<style>
    .share-buttons {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 0;
        margin: 1.5rem 0;
    }

    .share-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .share-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .share-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        padding: 0;
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .share-btn:hover {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: white;
        transform: translateY(-2px);
    }

    .share-btn:active {
        transform: translateY(0);
    }

    .copy-btn {
        position: relative;
    }

    .copy-btn .check-icon {
        display: none;
        position: absolute;
    }

    .copy-btn.copied .copy-icon {
        display: none;
    }

    .copy-btn.copied .check-icon {
        display: block;
    }

    .copy-btn.copied {
        background: #22c55e;
        border-color: #22c55e;
        color: white;
    }

    @media (max-width: 768px) {
        .share-buttons {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }

        .share-actions {
            flex-wrap: wrap;
        }

        .share-btn {
            width: 44px;
            height: 44px;
        }
    }
</style>

<script>
    // Copy to clipboard functionality
    document.addEventListener("DOMContentLoaded", () => {
        const copyButtons = document.querySelectorAll(".copy-btn");

        copyButtons.forEach((button) => {
            button.addEventListener("click", async () => {
                const url = button.getAttribute("data-url");

                if (!url) return;

                try {
                    await navigator.clipboard.writeText(url);

                    // Add visual feedback
                    button.classList.add("copied");

                    // Remove feedback after 2 seconds
                    setTimeout(() => {
                        button.classList.remove("copied");
                    }, 2000);
                } catch (err) {
                    console.error("Failed to copy:", err);

                    // Fallback for older browsers
                    const textArea = document.createElement("textarea");
                    textArea.value = url;
                    textArea.style.position = "fixed";
                    textArea.style.left = "-999999px";
                    document.body.appendChild(textArea);
                    textArea.select();

                    try {
                        document.execCommand("copy");
                        button.classList.add("copied");
                        setTimeout(() => {
                            button.classList.remove("copied");
                        }, 2000);
                    } catch (fallbackErr) {
                        console.error("Fallback copy failed:", fallbackErr);
                    }

                    document.body.removeChild(textArea);
                }
            });
        });
    });
</script>
