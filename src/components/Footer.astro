---
/**
 * Footer Component
 *
 * Site-wide footer displaying copyright information and social media links.
 * Automatically filters and displays only configured social links from site config.
 * Responsive layout that stacks vertically on mobile devices.
 *
 * Social links are pulled from siteConfig.social and only displayed if they have
 * a URL value configured. Links open in new tabs with proper security attributes.
 *
 * @component
 *
 * @example
 * ```astro
 * <Footer />
 * ```
 */
import { siteConfig } from "../data/index";
import NewsletterSignup from "./NewsletterSignup.astro";
import ThemeToggle from "./ThemeToggle.astro";

/**
 * Gets the current year for copyright display
 */
const currentYear = new Date().getFullYear();

/**
 * Filters and formats social links from site configuration
 *
 * Only includes platforms that have a URL configured (non-empty values).
 * Capitalizes platform names for display (e.g., "github" becomes "Github").
 *
 * @returns Array of social link objects with platform name and URL
 */
const socialLinks = siteConfig.social
  .filter((link) => !!link.url)
  .map((link) => ({
    label:
      link.label ||
      link.platform.charAt(0).toUpperCase() + link.platform.slice(1),
    url: link.url,
  }));
---

<footer class="site-footer">
  <NewsletterSignup />
  <div class="footer-container">
    <div class="footer-left">
      <span class="copyright">© {currentYear} {siteConfig.author.name}</span>
    </div>

    <div class="footer-center">
      <div class="footer-links">
        <a href="/cv" class="essential-link">CV</a>
        <span class="separator">·</span>
        <a href="/rss.xml" class="essential-link">RSS</a>
        <span class="separator">·</span>
        <a
          href="https://github.com/SinghChinmayy/website"
          target="_blank"
          rel="noopener noreferrer"
          class="essential-link">Source</a
        >
      </div>
    </div>

    <div class="footer-right">
      {
        socialLinks.length > 0 && (
          <div class="footer-social">
            {socialLinks.map((link, index) => (
              <>
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
                {index < socialLinks.length - 1 && (
                  <span class="separator-social">·</span>
                )}
              </>
            ))}
          </div>
        )
      }
      <div class="theme-toggle-wrapper">
        <ThemeToggle />
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem;
    margin-top: auto;
    background: var(--color-bg);
  }

  .footer-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-left {
    display: flex;
    justify-content: flex-start;
  }

  .footer-center {
    display: flex;
    justify-content: center;
  }

  .footer-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }

  .copyright {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .cms-link {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    opacity: 0.5;
  }

  .cms-link:hover {
    color: var(--color-text);
    background: var(--color-bg-secondary);
    border-color: var(--color-border);
    opacity: 1;
  }

  .cms-link svg {
    opacity: 0.7;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .essential-link {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    font-weight: 500;
  }

  .essential-link:hover {
    color: var(--color-text);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-social a {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-text);
  }

  .separator,
  .separator-social {
    color: var(--color-text-muted);
    opacity: 0.5;
    user-select: none;
    font-size: 0.8125rem;
  }

  .theme-toggle-wrapper {
    display: flex;
    align-items: center;
    padding-left: 1.5rem;
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }

    .footer-left,
    .footer-center,
    .footer-right {
      justify-content: center;
    }

    .footer-right {
      flex-direction: column;
      gap: 1rem;
    }

    .theme-toggle-wrapper {
      padding-left: 0;
      border-left: none;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border);
      width: 100%;
      justify-content: center;
    }
  }
</style>
